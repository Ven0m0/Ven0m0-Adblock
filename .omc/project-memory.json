      "lint:aglint": "bun x @adguard/aglint",
      "lint:fix": "bun x oxlint --fix . && bun x biome check --write . && bun x @adguard/aglint --fix",
      "lint:fix:all": "bun run lint:fix && bun run format",
      "format": "bun x biome format --write .",
      "format:check": "bun x biome format .",
      "test": "bun run lint && bun run format:check",
      "test:ci": "bun run lint && bun run format:check",
      "clean": "rm -rf node_modules dist lists/releases userscripts/dist Filters",
      "clean:cache": "rm -rf node_modules/.cache",
      "clean:all": "bun run clean && bun run clean:cache",
      "precommit": "bun run lint:fix:all",
      "validate": "bun run test && bun run build",
      "aglint": "bunx @adguard/aglint --cache --cache-location .aglintcache --cache-strategy content \"**/*.txt\""
    }
