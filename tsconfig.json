{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "lib": ["ES2015"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["scripts", ".eslintrc.js", "vitest.config.ts"],
  "exclude": ["node_modules"]
}
